# Database connection string
# For MySQL (production): mysql://username:password@host:3306/database
# For local development: mysql://root:password@localhost:3307/bookstore
DATABASE_URL="mysql://username:password@localhost:3307/bookstore"

# JWT Secret for authentication (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-secret-key-here-minimum-32-characters"

# Node environment
NODE_ENV="development"
